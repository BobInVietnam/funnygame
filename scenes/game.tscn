[sub_resource type="GDScript" id="GDScript_p57ef"]
script/source = "extends Node

@onready var princess = $Princess
@onready var spawnpoint = $Spawnpoint
var last_checkpoint_position: Vector2

func _ready() -> void:
	last_checkpoint_position = spawnpoint.global_position

func respawn_player(player: Princess) -> void:
	if player.current_retry > 0:
		print(\"reviving princess...\")
		player.current_retry -= 1
		player.global_position = last_checkpoint_position
		player.restore_from_checkpoint()
	else:
		player.restore_from_checkpoint()
		get_tree().reload_current_scene()
		


func _on_princess_princess_down() -> void:
	print(\"Princess retries: \", princess.current_retry)
	respawn_player(princess)


func _on_princess_checkpoint_passed(checkpoint: Vector2) -> void:
	last_checkpoint_position = checkpoint
"

